---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout title="About | Jay Patel" description="Learn about Jay Patel — background, story, and what he's working on.">
  <Header currentPage="/about" />
  <main>
    <section class="max-w-content mx-auto px-6 pt-16 pb-14">
      <h1 class="font-heading font-bold uppercase text-black">
        About Jay
      </h1>
      <div class="mt-10 space-y-6 font-body text-lg text-neutral-700 max-w-2xl leading-relaxed">
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor
          incididunt ut labore et dolore magna aliqua. Jay's bio and background will go here —
          his journey, values, and what drives his work.
        </p>
        <p>
          Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris. Current projects,
          interests, and how visitors can connect will be added by Jay.
        </p>
        <p>
          Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore.
          Optional personal notes, location, or fun facts.
        </p>
      </div>
    </section>

    <section class="border-t border-neutral-200 bg-surface">
      <div class="max-w-content mx-auto px-6 py-16 sm:py-24">
        <h2 class="font-heading font-bold uppercase text-black">
          Stay in the loop
        </h2>
        <p class="font-body text-neutral-600 mt-2 mb-6 max-w-xl">
          Get weekly updates and ideas. No spam — just one email per week.
        </p>
        <NewsletterForm />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
