---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout title="About | Pete McPherson" description="Learn about Pete McPherson — background, story, and what he's working on.">
  <Header currentPage="/about" />
  <main>
    <section class="max-w-content mx-auto px-6 pt-16 pb-12">
      <h1 class="font-heading font-bold text-4xl sm:text-5xl uppercase tracking-tight text-black">
        About Pete
      </h1>
      <div class="mt-12 space-y-6 font-body text-lg text-black/80 max-w-2xl leading-relaxed">
        <p>
          <!-- Placeholder: Pete's story and background -->
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor
          incididunt ut labore et dolore magna aliqua. Pete's bio and background will go here —
          his journey, values, and what drives his work.
        </p>
        <p>
          <!-- Placeholder: More about current focus -->
          Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris. Current projects,
          interests, and how visitors can connect will be added by Pete.
        </p>
        <p>
          <!-- Placeholder: Personal touch -->
          Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore.
          Optional personal notes, location, or fun facts.
        </p>
      </div>
    </section>

    <section class="border-t border-black mt-16">
      <div class="max-w-content mx-auto px-6 py-20">
        <h2 class="font-heading font-bold text-2xl uppercase text-black">
          Stay in the loop
        </h2>
        <p class="font-body text-black/80 mt-2 mb-6 max-w-xl">
          Get weekly updates and ideas. No spam — just one email per week.
        </p>
        <NewsletterForm />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
