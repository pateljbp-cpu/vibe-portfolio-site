---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Placeholder projects — Jay will replace with real titles and descriptions
const projects = [
  { title: 'Project One', description: 'Short placeholder description for the first project. Jay will add real content here.' },
  { title: 'Project Two', description: 'Short placeholder description for the second project. Replace with actual project details.' },
  { title: 'Project Three', description: 'Short placeholder description for the third project. Add link and summary as needed.' },
];
---

<BaseLayout title="Projects | Jay Patel" description="Explore Jay Patel's projects and work.">
  <Header currentPage="/projects" />
  <main>
    <section class="max-w-content mx-auto px-6 pt-16 pb-10">
      <h1 class="font-heading font-bold uppercase text-black">
        Projects
      </h1>
      <p class="font-body text-lg text-neutral-600 mt-4 max-w-2xl">
        A selection of work and side projects. More coming soon.
      </p>
    </section>

    <section class="max-w-content mx-auto px-6 pb-20">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            href="#"
          />
        ))}
      </div>
    </section>

    <section class="border-t border-neutral-200 bg-surface">
      <div class="max-w-content mx-auto px-6 py-16 sm:py-24">
        <h2 class="font-heading font-bold uppercase text-black">
          Get the newsletter
        </h2>
        <p class="font-body text-neutral-600 mt-2 mb-6 max-w-xl">
          Weekly ideas and updates. One email, no clutter.
        </p>
        <NewsletterForm />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
