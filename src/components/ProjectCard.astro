---
interface Props {
  title: string;
  description: string;
  href?: string;
}

const { title, description, href = '#' } = Astro.props;
---

<article class="rounded-lg border border-neutral-200 bg-white p-6 shadow-card hover:shadow-card-hover hover:border-accent/50 transition-all duration-200">
  <a href={href} class="block group">
    <h3 class="font-heading font-bold text-lg uppercase text-black group-hover:text-accent transition-colors">
      {title}
    </h3>
    <p class="font-body text-sm mt-2 text-neutral-600 leading-relaxed">
      {description}
    </p>
    <span class="inline-block mt-4 font-body text-sm font-medium text-accent uppercase tracking-wide group-hover:underline">
      View project →
    </span>
  </a>
</article>
