---
interface Props {
  title: string;
  description: string;
  href?: string;
}

const { title, description, href = '#' } = Astro.props;
---

<article class="border-2 border-black p-6 hover:border-accent transition-colors">
  <a href={href} class="block group">
    <h3 class="font-heading font-bold text-lg uppercase text-black group-hover:text-accent transition-colors">
      {title}
    </h3>
    <p class="font-body text-sm mt-2 text-black/80">
      {description}
    </p>
    <span class="inline-block mt-3 font-body text-sm font-medium text-accent uppercase tracking-wide">
      View project →
    </span>
  </a>
</article>
